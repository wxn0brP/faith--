# Faith-- number guessing game
# Random target 1-100

target = 0
loop 100
    target = target - 1
end

running = 1
print('guess a number between 1 and 100')

switch running
    guess = read('> ')

    eq = guess =~ target
    low = guess ][ target
    high = guess [] target

    else low
        print('too low')
    end

    else high
        print('too high')
    end

    else eq
        print('correct')
        running = 0
    end
end
